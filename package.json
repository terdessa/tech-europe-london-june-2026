{
  "name": "rahid-retrieval",
  "version": "0.1.0",
  "private": true,
  "description": "Rahid P2 — Retrieval & Context service (SQLite source-of-truth + Superlinked SIE semantic layer).",
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed:retrieval": "tsx src/seed.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
