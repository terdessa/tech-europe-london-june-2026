# Flash — single root env. Copy to .env and fill in. NEVER commit .env (gitignored).
# Placeholders only — no real secrets in the repo (Aikido scans this).

# --- Gemini (Brain + Vision, used by n8n & P1) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# --- Superlinked SIE (P2 retrieval semantic layer) ---
# Hackathon endpoint (SIE Quickstart). Self-host: http://localhost:8080.
SUPERLINKED_ENDPOINT=http://a64e1dc31032c40e4b1e9330a1273c83-1760332796.us-east-2.elb.amazonaws.com:8080
# API key — message @filipmakraduli on Discord. Format: SL-<hex>
SUPERLINKED_API_KEY=
SUPERLINKED_MODE=sie

# --- SLNG voice (P1 ears + mouth) ---
SLNG_API_KEY=
SLNG_TTS_URL=https://api.slng.ai/v1/tts/slng/deepgram/aura:2-en
SLNG_TTS_MODEL=aura-2-arcas-en
SLNG_STT_URL=https://api.slng.ai/v1/stt/slng/deepgram/nova:3-en
VOICE=slng

# --- Google Meet bot (P1) ---
MEET_MODE=real
FLASH_DISPLAY_NAME=Flash
# Leave MEET_URL blank: the dashboard "Add Flash" button drives /join per meetingId.
MEET_URL=
# Leave blank to join as a guest named Flash (recommended).
MEET_USER_DATA_DIR=
# Eyes on: Flash watches shared screens and turns graphs/tables into context + nodes.
SCREEN_CAPTURE=on
SCREEN_INTERVAL_MS=12000
SCREEN_WATCH_ALWAYS=off

# --- Service URLs (how the tracks find each other) ---
AGENT_PORT=8001
AGENT_URL=http://localhost:8001
CONTEXT_SERVICE_URL=http://localhost:3000
PORT=3000
SQLITE_PATH=./data/retrieval.db
N8N_WEBHOOK_BASE=http://localhost:5678/webhook
FACE_URL=http://localhost:3001
