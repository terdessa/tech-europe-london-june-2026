# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Placeholders only — no real secrets in the repo.

# --- Gemini (P3) ---
GEMINI_API_KEY=

# --- Superlinked (P2) ---
SUPERLINKED_ENDPOINT=
SUPERLINKED_API_KEY=

# --- SLNG voice (P1) ---
SLNG_API_KEY=
SLNG_TTS_URL=
# VOICE=console (log only) | slng (real TTS)
VOICE=console

# --- Google Meet bot (P1) ---
# If using a managed bot service (Recall.ai / MeetingBaaS):
MEET_BOT_API_KEY=
# If using LiveKit (Media-API-style per-participant or the fallback room):
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- service URLs (how the tracks find each other) ---
AGENT_URL=http://localhost:8001
CONTEXT_SERVICE_URL=http://localhost:8002
N8N_WEBHOOK_BASE=http://localhost:5678/webhook
