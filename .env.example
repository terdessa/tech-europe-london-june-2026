# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Placeholders only — no real secrets in the repo.

# --- Gemini (P3) ---
GEMINI_API_KEY=

# --- Superlinked (P2) ---
SUPERLINKED_ENDPOINT=
SUPERLINKED_API_KEY=

# --- SLNG voice (P1) ---
SLNG_API_KEY=
SLNG_TTS_URL=
# VOICE=console (log only) | local (Windows TTS, zero-key) | slng (real TTS)
VOICE=local

# --- Google Meet bot (P1) ---
# MEET_MODE=mock (replay sample transcript) | real (join a Google Meet via Playwright)
MEET_MODE=real
# Display name Flash uses in the meeting
FLASH_DISPLAY_NAME=Flash
# Chrome profile dir (sign in to Google once; reused after). Default: agent/.meet-profile
MEET_USER_DATA_DIR=
# Eyes: SCREEN_CAPTURE=on enables "Hey Flash, …screen…" -> describe the shared screen
SCREEN_CAPTURE=off
# Optional: lets the eyes feature work with NO backend (direct Gemini). Leave blank if none.
GEMINI_MODEL=gemini-2.5-flash

# (Optional alternative join paths)
MEET_BOT_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- service URLs (how the tracks find each other) ---
AGENT_URL=http://localhost:8001
CONTEXT_SERVICE_URL=http://localhost:8002
N8N_WEBHOOK_BASE=http://localhost:5678/webhook
