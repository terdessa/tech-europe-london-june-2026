# --- Flash P2 — Retrieval & Context (Superlinked SIE) -----------------------
# Public base URL other services use to talk to P2.
CONTEXT_SERVICE_URL=http://localhost:3000

# Port the P2 service listens on.
PORT=3000

# Path to the SQLite database (source of truth for raw utterances + sources).
SQLITE_PATH=./data/retrieval.db

# --- Superlinked Inference Engine (SIE) -------------------------------------
# Hackathon endpoint (publicly shared in the SIE Hackathon Quickstart).
# Self-host alternative: http://localhost:8080 (docker run superlinked/sie-server).
SUPERLINKED_ENDPOINT=http://a64e1dc31032c40e4b1e9330a1273c83-1760332796.us-east-2.elb.amazonaws.com:8080

# API key — message @filipmakraduli on Discord. Format: SL-<hex>
SUPERLINKED_API_KEY=

# (Reserved) Some deployments distinguish a cluster URL from the per-request endpoint.
SUPERLINKED_CLUSTER_URL=

# Which Superlinked interface we use. We use the SIE HTTP API.
# Valid: "sie" (default) | "framework"
SUPERLINKED_MODE=sie

# GPU lane on the hosted cluster. l4 is fine for small encoders/rerankers;
# rtx6000 is for larger generative models. See quickstart for the lanes.
SUPERLINKED_GPU=l4

# Cold model load can take ~1 min on first call. SDK polls until ready.
SUPERLINKED_PROVISION_TIMEOUT_MS=900000

# SIE model IDs (override to swap models without code changes).
# Defaults match the quickstart — small, fast, hackathon-friendly.
SUPERLINKED_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
SUPERLINKED_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
SUPERLINKED_DOC_MODEL=docling

# --- Flash workflow / brain --------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_VISION_MODEL=gemini-3.5-flash
N8N_WEBHOOK_BASE=http://localhost:5678/webhook
AIKIDO_WEBHOOK_URL=
