# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Placeholders only — no real secrets in the repo.

# --- Gemini (P3) ---
GEMINI_API_KEY=

# --- Superlinked (P2) ---
SUPERLINKED_ENDPOINT=
SUPERLINKED_API_KEY=

# --- SLNG voice (P1) ---
SLNG_API_KEY=
SLNG_TTS_URL=https://api.slng.ai/v1/tts/slng/deepgram/aura:2-en
SLNG_TTS_MODEL=aura-2-thalia-en
# STT (ears): captures meeting audio -> transcript
SLNG_STT_URL=https://api.slng.ai/v1/stt/slng/deepgram/nova:3-en
# VOICE=console (log only) | local (Windows TTS, zero-key) | slng (real TTS)
VOICE=local

# --- Google Meet bot (P1) ---
# MEET_MODE=mock (replay sample transcript) | real (join a Google Meet via Playwright)
MEET_MODE=real
# Display name Flash uses in the meeting
FLASH_DISPLAY_NAME=Flash
# Auto-join this meeting on startup (paste your Meet link here). Blank = wait for /join.
MEET_URL=
# Leave BLANK to join as a separate GUEST named Flash (recommended).
# Set to a profile dir only to sign in with a DEDICATED Flash Google account.
MEET_USER_DATA_DIR=
# Eyes: voice-only by default. SCREEN_CAPTURE=on -> Flash watches a shared screen (needs GEMINI_API_KEY).
SCREEN_CAPTURE=off
SCREEN_INTERVAL_MS=12000
SCREEN_WATCH_ALWAYS=off
GEMINI_MODEL=gemini-2.5-flash

# (Optional alternative join paths)
MEET_BOT_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- service URLs ---
# Set CONTEXT_SERVICE_URL / N8N_WEBHOOK_BASE only when P2 / P3 are running.
# Leave them BLANK for P1-only / no-backend (uses local files + stub).
AGENT_URL=http://localhost:8001
CONTEXT_SERVICE_URL=
N8N_WEBHOOK_BASE=
